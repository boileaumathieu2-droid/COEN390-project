<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/layout"
        android:layout_width="374dp"
        android:layout_height="593dp"
        android:layout_marginStart="18dp"
        android:layout_marginTop="42dp"
        android:layout_marginEnd="18dp"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/studySeshFinishTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Study Session Finished!"
            android:textColor="#000000"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textView"
            android:layout_width="match_parent"
            android:layout_height="74dp"
            android:gravity="center"
            android:text="Did you complete your goal for the session?"
            android:textColor="#000000"
            android:textSize="20sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="49dp"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnYes"
                android:layout_width="111dp"
                android:layout_height="match_parent"
                android:backgroundTint="#2A9E05"
                android:text="Yes"
                android:textColor="#FFFFFF" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <Button
                android:id="@+id/btnNo"
                android:layout_width="111dp"
                android:layout_height="match_parent"
                android:backgroundTint="#FF0000"
                android:text="No"
                android:textColor="#FFFFFF" />

        </LinearLayout>

        <TextView
            android:id="@+id/rateProductivityTextView"
            android:layout_width="match_parent"
            android:layout_height="77dp"
            android:gravity="center"
            android:text="Rate your productivity out of 10"
            android:textColor="#000000"
            android:textSize="20sp" />

        <EditText
            android:id="@+id/editTextNumber"
            android:layout_width="337dp"
            android:layout_height="59dp"
            android:ems="10"
            android:hint="1-10"
            android:inputType="number"
            android:textSize="20sp" />

        <Button
            android:id="@+id/extendSeshButton"
            android:layout_width="335dp"
            android:layout_height="68dp"
            android:text="Extend Session"
            android:textSize="20sp" />

        <Button
            android:id="@+id/finishSeshButton"
            android:layout_width="match_parent"
            android:layout_height="68dp"
            android:text="Finish Session"
            android:textSize="20sp" />

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
