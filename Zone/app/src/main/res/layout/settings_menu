<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0">

        <TextView
            android:id="@+id/appRestrictButton"
            android:layout_width="285dp"
            android:layout_height="44dp"
            android:layout_gravity="center"
            android:layout_marginTop="140dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/textview_border1"
            android:gravity="center_vertical"
            android:padding="10dp"
            android:text="App Restrict"
            android:textColor="#000000"
            android:textSize="18dp" />

        <TextView
            android:id="@+id/notificationsButton"
            android:layout_width="285dp"
            android:layout_height="44dp"
            android:layout_gravity="center"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/textview_border1"
            android:gravity="center_vertical"
            android:padding="10dp"
            android:text="Notifications"
            android:textColor="#000000"
            android:textSize="18dp" />

        <TextView
            android:id="@+id/connectDeviceButton"
            android:layout_width="285dp"
            android:layout_height="44dp"
            android:layout_gravity="center"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/textview_border1"
            android:gravity="center_vertical"
            android:padding="10dp"
            android:text="Connect Device"
            android:textColor="#000000"
            android:textSize="18dp" />

        <TextView
            android:id="@+id/aboutHelpButton"
            android:layout_width="285dp"
            android:layout_height="44dp"
            android:layout_gravity="center"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/textview_border1"
            android:gravity="center_vertical"
            android:padding="10dp"
            android:text="About/Help"
            android:textColor="#000000"
            android:textSize="18dp" />

        <TextView
            android:id="@+id/logoutButton"
            android:layout_width="285dp"
            android:layout_height="44dp"
            android:layout_gravity="center"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/textview_border1"
            android:gravity="center_vertical"
            android:padding="10dp"
            android:text="Logout"
            android:textColor="#000000"
            android:textSize="18dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
