<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/detailTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Session Details"
            android:textAlignment="center"
            android:textColor="@color/black"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/detailStartEnd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textAlignment="center"
            android:textColor="@color/zone_text_secondary" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="16dp"
            android:background="#DDDDDD" />

        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/detailChart"
            android:layout_width="match_parent"
            android:layout_height="200dp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:columnCount="2">

            <TextView android:text="Avg Heart Rate:" android:textStyle="bold" />
            <TextView android:id="@+id/detailAvgHR" android:layout_gravity="end" />

            <TextView android:text="Resting Heart Rate:" android:textStyle="bold" />
            <TextView android:id="@+id/detailRestingHR" android:layout_gravity="end" />

            <TextView android:text="Max Heart Rate:" android:textStyle="bold" />
            <TextView android:id="@+id/detailMaxHR" android:layout_gravity="end" />

            <TextView android:text="Min Heart Rate:" android:textStyle="bold" />
            <TextView android:id="@+id/detailMinHR" android:layout_gravity="end" />

            <TextView android:text="Duration:" android:textStyle="bold" />
            <TextView android:id="@+id/detailDuration" android:layout_gravity="end" />

            <TextView android:text="Productivity:" android:textStyle="bold" />
            <TextView android:id="@+id/detailProductivity" android:layout_gravity="end" />

            <TextView android:text="Objective Met:" android:textStyle="bold" />
            <TextView android:id="@+id/detailObjectiveMet" android:layout_gravity="end" />

        </GridLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/deleteButton"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Delete"
                android:textColor="@color/zone_warning" />

            <Button
                android:id="@+id/closeButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Close" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>