<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/zone_background"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="12dp"
    android:paddingEnd="16dp"
    android:paddingBottom="12dp">

    <CalendarView
        android:id="@+id/objectiveCalendar"
        android:layout_width="match_parent"
        android:layout_height="310dp"
        android:background="@color/white"
        android:dateTextAppearance="@style/CalendarDateText"
        android:weekDayTextAppearance="@style/CalendarWeekText" />

    <TextView
        android:id="@+id/selectedDateTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textColor="@color/zone_text_primary"
        android:textSize="18sp"
        android:textStyle="bold" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="6dp"
        android:layout_weight="1"
        android:background="@drawable/device_list_background"
        android:minHeight="80dp">

        <ListView
            android:id="@+id/selectedDateTasks"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="@color/zone_border"
            android:dividerHeight="1dp" />

        <TextView
            android:id="@+id/noTasksText"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:padding="16dp"
            android:text="@string/no_tasks_for_date"
            android:textColor="@color/zone_text_secondary"
            android:textSize="14sp" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        android:weightSum="2">

        <Button
            android:id="@+id/newObjectiveButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:text="@string/create_task"
            android:textColor="@color/white"
            app:icon="@drawable/outline_add_24"
            app:iconGravity="textStart"
            app:iconSize="20dp" />

        <Button
            android:id="@+id/myObjectivesButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:text="My Objectives"
            android:textColor="@color/white" />
    </LinearLayout>
</LinearLayout>
