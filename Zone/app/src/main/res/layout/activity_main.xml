<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".view.MainView">

    <LinearLayout
        android:layout_width="417dp"
        android:layout_height="727dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/dailyObjectiveText"
            android:layout_width="281dp"
            android:layout_height="45dp"
            android:layout_gravity="center"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="18dp"
            android:gravity="center"
            android:text="Daily Objective"
            android:textColor="#000000"
            android:textSize="24sp"
            android:textStyle="bold" />

        <ScrollView
            android:id="@+id/dailyObjectiveWindow"
            android:layout_width="343dp"
            android:layout_height="133dp"
            android:layout_gravity="center"
            android:layout_marginStart="30dp"
            android:layout_marginEnd="30dp"
            android:background="@drawable/textview_border"
            android:padding="10dp">

            <TextView
                android:id="@+id/objectiveScrollableText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:text="Daily objective goes here"
                android:textColor="#000000"
                android:textSize="18sp" />

        </ScrollView>

        <TextView
            android:id="@+id/studyTipTextView"
            android:layout_width="263dp"
            android:layout_height="33dp"
            android:layout_gravity="center"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="18dp"
            android:text="A study tip will be displayed here"
            android:textColor="#000000" />

        <Button
            android:id="@+id/timerSettings"
            android:layout_width="222dp"
            android:layout_height="52dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:text="Timer Settings" />

        <Button
            android:id="@+id/startStudySeshButton"
            android:layout_width="222dp"
            android:layout_height="52dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="18dp"
            android:text="Start Study Session" />

        <Button
            android:id="@+id/gradesTrackerButton"
            android:layout_width="222dp"
            android:layout_height="52dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="18dp"
            android:text="Grades Tracker" />

        <TextView
            android:id="@+id/timerTitle"
            android:layout_width="263dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="8dp"
            android:gravity="center"
            android:text="Study Time"
            android:textColor="#000000"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/timerDisplay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="18dp"
            android:text="00:00"
            android:textColor="#000000"
            android:textSize="48sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/pauseTimer"
            android:layout_width="111dp"
            android:layout_height="42dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="18dp"
            android:text="Pause"
            android:visibility="gone" />

        <Button
            android:id="@+id/resetTimer"
            android:layout_width="111dp"
            android:layout_height="42dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="18dp"
            android:text="Reset"
            android:visibility="gone" />

        <Button
            android:id="@+id/completeTimer"
            android:layout_width="111dp"
            android:layout_height="42dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="18dp"
            android:text="Complete"
            android:visibility="gone" />


    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
