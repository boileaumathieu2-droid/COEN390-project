<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/zone_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/create_task"
            android:textColor="@color/zone_text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="@string/event_name"
            android:textColor="@color/zone_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/eventNameInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/event_name_hint"
            android:inputType="textCapSentences"
            android:minHeight="52dp"
            android:textColor="@color/zone_text_primary"
            android:textColorHint="@color/zone_text_secondary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/due_date"
            android:textColor="@color/zone_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/dueDateButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/completion_time"
            android:textColor="@color/zone_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/completionTimeInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/completion_time_hint"
            android:inputType="number"
            android:minHeight="52dp"
            android:textColor="@color/zone_text_primary"
            android:textColorHint="@color/zone_text_secondary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/task_type"
            android:textColor="@color/zone_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/taskTypeSpinner"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/reading_details_background"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/objectives"
            android:textColor="@color/zone_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/objectivesInput"
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:gravity="top|start"
            android:hint="@string/objectives_hint"
            android:inputType="textCapSentences|textMultiLine"
            android:paddingTop="12dp"
            android:textColor="@color/zone_text_primary"
            android:textColorHint="@color/zone_text_secondary" />

        <Button
            android:id="@+id/saveTaskButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="24dp"
            android:text="@string/save_task"
            android:textColor="@color/white" />
    </LinearLayout>
</ScrollView>
