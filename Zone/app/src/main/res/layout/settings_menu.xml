<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#FFFFFF"

        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/appRestrictButton"
            android:layout_width="285dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="100dp"
            android:gravity="center|start"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:text="App Restrict"
            android:textColor="@color/white"
            android:textSize="20sp"
            app:backgroundTint="@color/blue0"
            app:cornerRadius="10dp"
            app:icon="@drawable/icon_android_black_24dp"
            app:iconGravity="start"
            app:iconPadding="8dp"
            app:iconSize="22dp"
            app:iconTint="@color/white" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/notificationsButton"
            android:layout_width="285dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="18dp"
            android:gravity="center|start"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:text="Notifications"
            android:textColor="@color/white"
            android:textSize="20sp"
            app:backgroundTint="@color/blue0"
            app:cornerRadius="10dp"
            app:icon="@drawable/icon_round_edit_notifications_24"
            app:iconGravity="start"
            app:iconPadding="8dp"
            app:iconSize="22dp"
            app:iconTint="@color/white" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/connectDeviceButton"
            android:layout_width="285dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="18dp"
            android:gravity="center|start"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:text="Connect Device"
            android:textColor="@color/white"
            android:textSize="20sp"
            app:backgroundTint="@color/blue0"
            app:cornerRadius="10dp"
            app:icon="@drawable/icon_outline_bluetooth_24"
            app:iconGravity="start"
            app:iconPadding="8dp"
            app:iconSize="22dp"
            app:iconTint="@color/white" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/aboutHelpButton"
            android:layout_width="285dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="18dp"
            android:gravity="center|start"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:text="About/Help"
            android:textColor="@color/white"
            android:textSize="20sp"
            app:backgroundTint="@color/blue0"
            app:cornerRadius="10dp"
            app:icon="@drawable/icon_round_info_outline_24"
            app:iconGravity="start"
            app:iconPadding="8dp"
            app:iconSize="22dp"
            app:iconTint="@color/white" />


        <com.google.android.material.button.MaterialButton
            android:id="@+id/logoutButton"
            android:layout_width="285dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="18dp"
            android:gravity="center|start"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:text="Logout"
            android:textColor="@color/white"
            android:textSize="20sp"
            app:backgroundTint="@color/blue0"
            app:cornerRadius="10dp"
            app:icon="@drawable/icon_baseline_logout_24"
            app:iconGravity="start"
            app:iconPadding="8dp"
            app:iconSize="22dp"
            app:iconTint="@color/white" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
